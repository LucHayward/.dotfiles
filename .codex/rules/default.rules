prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["git", "fetch"], decision="allow")
prefix_rule(pattern=["git", "pull"], decision="allow")
prefix_rule(pattern=["git", "stash", "push"], decision="allow")
prefix_rule(pattern=["git", "stash", "pop"], decision="allow")
prefix_rule(pattern=["git", "stash", "apply"], decision="allow")
prefix_rule(pattern=["git", "stash", "list"], decision="allow")
prefix_rule(pattern=["sed", "-n"], decision="allow")
prefix_rule(pattern=["rg"], decision="allow")
prefix_rule(pattern=["jq"], decision="allow")
prefix_rule(pattern=["tmux", "list-panes"], decision="allow")
prefix_rule(pattern=["pstree", "-ap"], decision="allow")
prefix_rule(pattern=["ps", "-o"], decision="allow")
prefix_rule(pattern=["tmux", "capture-pane"], decision="allow")
prefix_rule(pattern=["du", "-sh"], decision="allow")
prefix_rule(pattern=["lsof", "-nP"], decision="allow")
prefix_rule(pattern=["stat", "-c"], decision="allow")
prefix_rule(pattern=["unzip", "-t"], decision="allow")
prefix_rule(pattern=["ps", "-L"], decision="allow")
prefix_rule(pattern=["df", "-h"], decision="allow")
prefix_rule(pattern=["printenv", "PATH"], decision="allow")
prefix_rule(pattern=["kiro-cli", "chat"], decision="allow")
