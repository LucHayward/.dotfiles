{
  "awsCredentialExport": "\"/Users/luchay/.toolbox/bin/claude\" default-credential-export",
  "env": {
    "AWS_REGION": "us-west-2",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "global.anthropic.claude-sonnet-5",
  "fallbackModel": [
    "global.anthropic.claude-opus-4-8[1m]"
  ],
  "availableModels": [
    "claude-opus-4-6[1m]",
    "claude-opus-4-6",
    "claude-opus-4-7[1m]",
    "claude-opus-4-7",
    "claude-opus-4-8[1m]",
    "claude-opus-4-8",
    "claude-sonnet-4-6",
    "claude-sonnet-4-6[1m]",
    "claude-sonnet-5",
    "claude-fable-5",
    "claude-fable-5[1m]",
    "claude-haiku-4-5"
  ],
  "enforceAvailableModels": true,
  "modelOverrides": {
    "claude-opus-4-6[1m]": "global.anthropic.claude-opus-4-6-v1[1m]",
    "claude-opus-4-6": "global.anthropic.claude-opus-4-6-v1",
    "claude-opus-4-7[1m]": "global.anthropic.claude-opus-4-7[1m]",
    "claude-opus-4-7": "global.anthropic.claude-opus-4-7",
    "claude-opus-4-8[1m]": "global.anthropic.claude-opus-4-8[1m]",
    "claude-opus-4-8": "global.anthropic.claude-opus-4-8",
    "claude-sonnet-4-6": "global.anthropic.claude-sonnet-4-6",
    "claude-sonnet-4-6[1m]": "global.anthropic.claude-sonnet-4-6[1m]",
    "claude-sonnet-5": "global.anthropic.claude-sonnet-5",
    "claude-fable-5": "global.anthropic.claude-fable-5[1m]",
    "claude-fable-5[1m]": "global.anthropic.claude-fable-5[1m]",
    "claude-haiku-4-5": "global.anthropic.claude-haiku-4-5-20251001-v1:0"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "cship"
  },
  "enabledPlugins": {
    "AmazonBuilderCoreAIAgents-core@aim": true,
    "AmazonBuilderCoreAIAgents-pipeline-assistant@aim": true,
    "AIPowerUserCapabilities-core-dev@aim": true,
    "AIPowerUserCapabilities-code-review@aim": true,
    "AIPowerUserCapabilities-comms@aim": false,
    "AIPowerUserCapabilities-writing@aim": false,
    "AIPowerUserCapabilities-research@aim": false,
    "ChorusAIM-all@aim": true,
    "MfArbalestAICapabilities-all@aim": true
  },
  "extraKnownMarketplaces": {
    "aim": {
      "source": {
        "source": "directory",
        "path": "~/.aim/cc-plugins"
      }
    }
  },
  "syntaxHighlightingDisabled": false,
  "effortLevel": "xhigh",
  "askUserQuestionTimeout": "never",
  "companyAnnouncements": [
    "Claude Code usage is cleared for Business Data per the AI For Me Guidance.\nITAR, PII, Customer Data, and more are strictly prohibited for use within this tool.\nRead more: https://w.amazon.com/bin/view/Security/AI-Security/AIforMe-Guidance#HDATAANDEXAMPLESQUICKREFERENCETABLE"
  ],
  "autoMemoryEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "editorMode": "normal",
  "verbose": false,
  "preferredNotifChannel": "auto",
  "autoCompactEnabled": true,
  "teammateMode": "auto"
}