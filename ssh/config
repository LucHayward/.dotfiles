# Automatic SSH Config for all Cataclyst/kVPC hosts 
# https://managedbuilds.corp.amazon.com/platform/access/LTW
# Don't proxy Catalyst bastions
Host catalyst-prod-bastion-*
  ProxyCommand none

# Proxy through Catalyst bastions for Catalyst kVPC Instances: Prod and Substrate
Host *-vpc.* *vpc-*
  ProxyCommand ssh -Aqx -o CheckHostIp=no -o StrictHostKeyChecking=no -At catalyst-prod-bastion-`echo %h | awk -F. '{print $(NF-2)}' | sed -e 's/-//' -e 's/[0-9]*$//g'`.ec2.amazon.com nc %h %p
