### Don't save ops hosts to known_hosts ###
Host aws-foundry-ops-*
  UserKnownHostsFile /dev/null
  StrictHostKeyChecking no

# Prod Bastion SSH Config additions. See https://w.amazon.com/bin/view/PROD_Security_Bastions
# for details and contact information.
# OpenSSH 8.8 disables RSA signatures using the SHA-1 hash algorithm by default
# We're adding this option to make clients running OpenSSH v8.8 compatible with OpenSSH v7.4 on AL2 servers.
# https://t.corp.amazon.com/V444963807/communication
Host *
  PubkeyAcceptedKeyTypes +ssh-rsa-cert-v01@openssh.com

# Do not try to proxy when going straight to a bastion host
Host security-bastions-prod-??? security-bastions-prod-???.amazon.com bastion-??? bastion-???.amazon.com bastion-???.corp.amazon.com
  ProxyCommand none

# Do not try to proxy when accessing a corp host
Host *.corp.amazon.com *.corp.amazon.com. *corp*.amazon.com *corp*.amazon.com. *.desktop.amazon.com *.desktop.amazon.com. dev-dsk-*.amazon.com dev-dsk-*.amazon.com. *sealab*.amazon.com *sealab*.amazon.com. *-i-d-*.amazon.com *-i-pd-*.amazon.com !bastion-???.corp.amazon.com
  ProxyCommand none

# Configuration for db.amazon.com CNAMEs. We need to identify where the end host
# is via DNS in order to pick the right bastion
Host *.db*.amazon.com *.db? *.db?? .db
  HostName %h
  ProxyCommand ssh -W %h:%p bastion-`echo %h | xargs host | grep alias | awk '{print $6}' | awk -F. '{print $2}' | sed -E 's/[0-9]{1,}$//' | tail -n 1`.corp.amazon.com

